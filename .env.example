# =============================================================================
# aiFrontCR 环境变量模板 —— 复制为 .env 并填入真实值（.env 不入仓）
# =============================================================================

# ====== 阿里通义千问（必填，阶段0 验收核心）======
# 申请：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-replace-with-your-key
# 兼容模式 base_url（OpenAI 协议），用于 ChatOpenAI 方式调用
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Qwen3-Max 模型标识（若官方模型名变更请同步）
QWEN_CHAT_MODEL=qwen3.7-max
QWEN_TEMPERATURE=0.1
QWEN_MAX_TOKENS=4096
DASHSCOPE_TIMEOUT=30

# ====== 应用配置 ======
APP_NAME=aiFrontCR
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ====== 日志 ======
LOG_LEVEL=INFO
LOG_DIR=./logs

# ====== 阶段1：知识库 RAG + Web 后台 ======
# Redis Stack（带 RediSearch 模块）；本地起：docker run -d -p 6379:6379 redis/redis-stack:latest
REDIS_URL=redis://localhost:6379/0
# Redis 向量索引名（单库多类型架构：spec/review_case/feedback 全部进这里）
REDIS_INDEX_NAME=aiFrontCR:kb

# Embedding 后端（dashscope=API 免下载；local=本地 BGE-M3 需下载）
EMBEDDING_BACKEND=dashscope
EMBEDDING_MODEL_ID=text-embedding-v3   # dashscope 用 v3(1024 维) / local 用 BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cpu   # local 后端用

# Rerank 后端（dashscope=gte-rerank；local=BGE-Reranker-v2-m3）
RERANK_BACKEND=dashscope
RERANK_MODEL_ID=gte-rerank

# 本地后端的模型缓存目录（dashscope 不用）
HF_HOME=./.cache/huggingface

# 切片参数
CHUNK_SIZE=600
CHUNK_OVERLAP=120
# 检索参数
RETRIEVAL_TOP_K=5
VECTOR_TOP_K=30
KEYWORD_TOP_K=20
# 阶段6 RAG 调优：rerank 分数下限（0~1，低于此值丢弃；0=不过滤；建议 0.3~0.5）
MIN_RERANK_SCORE=0.0

# Web 后台鉴权（简易密码，admin 一把钥匙）
ADMIN_PASSWORD=admin123
# Session 签名密钥（生产用 openssl rand -hex 32 生成）
SESSION_SECRET=replace-with-openssl-rand-hex-32-secret

# 飞书私域文档解析
FEISHU_APP_ID=cli_replace-with-your-app-id
FEISHU_APP_SECRET=replace-with-your-app-secret
FEISHU_BRAND=feishu
