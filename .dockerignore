# 排除不需要打进镜像的文件（减小镜像体积 + 加速构建）
# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 测试（保留在镜像里，make test 可用；想省体积可改成 tests/）
.tox/
.coverage
htmlcov/
.pytest_cache/

# 日志 / 临时
logs/
*.log
tmp/
temp/
.tmp/

# 缓存
.cache/
.data/
*.pid
*.sock

# Git / IDE
.git/
.gitignore
.gitattributes
.idea/
.vscode/
.DS_Store

# 文档
doc/
*.md
!README.md

# 数据（运行时挂载，不打进镜像；bootstrap 例外：seed 脚本需要）
data/
uploads/
!data/bootstrap/.gitkeep
!data/bootstrap/specs/
!data/bootstrap/specs/*.md
!data/bootstrap/reviews/
!data/bootstrap/reviews/*.md

# Docker 自身
Dockerfile
docker-compose*.yml
.dockerignore

# 环境变量（运行时注入，不打进镜像）
.env
.env.local
